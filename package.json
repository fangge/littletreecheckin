  "type": "module",
  "scripts": {
    "start": "(trap 'kill 0' SIGINT; pnpm dev & pnpm server:dev & wait)",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
