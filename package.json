{
  "name": "littletreecheckin",
  "private": true,
  "version": "3.1",
  "type": "module",
  "scripts": {
    "start": "concurrently -n \"前端,后端\" -c \"blue,green\" \"pnpm dev\" \"pnpm server:dev\"",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cert": "node scripts/generate-cert.js",
    "server:dev": "cd server && pnpm dev",
    "server:start": "cd server && pnpm start"
  },
  "dependencies": {
    "@dgreenheck/ez-tree": "^1.1.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^19.2.14",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.1.14",
    "three": "^0.184.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitepress": "^1.5.0"
  }
}
