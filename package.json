{
  "name": "littletreecheckin",
  "private": true,
  "version": "3.1",
  "type": "module",
  "scripts": {
    "start": "concurrently -n \"前端,后端\" -c \"blue,green\" \"pnpm dev\" \"pnpm server:dev\"",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "cert": "node scripts/generate-cert.js",
    "server:dev": "cd server && pnpm dev",
    "server:start": "cd server && pnpm start"
  },
  "dependencies": {
    "@dgreenheck/ez-tree": "^1.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "three": "^0.184.0",
    "vconsole": "^3.15.1",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.17",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^6.2.0",
    "vitepress": "^1.6.4"
  }
}
